# Build stage for the Go controller
FROM golang:1.21-bookworm AS builder

# Install BPF build dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    clang llvm libbpf-dev linux-headers-generic bpftool \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .

# Build BPF program
RUN cd bpf && make

# Build Go controller
RUN CGO_ENABLED=1 go build -o /bin/controller ./cmd/controller

# ── Runtime stage ──
FROM debian:bookworm-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    libbpf1 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /bin/controller /usr/local/bin/controller
COPY --from=builder /app/bpf/xdp_prog.o /opt/ddos/bpf/xdp_prog.o
COPY configs/config.yaml /opt/ddos/configs/config.yaml

# ONNX model must be mounted or copied separately
VOLUME /opt/ddos/ml/models

WORKDIR /opt/ddos
ENTRYPOINT ["controller", "--config", "configs/config.yaml"]
